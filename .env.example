# SparkSage configuration template.
#
# Copy to `.env` and fill in your values:   cp .env.example .env
# `.env` is git-ignored -- never commit real secrets.
#
# Priority (highest first), per the 12-factor convention:
#   1. Real environment variables (container / CI / shell `export`)
#   2. Values in this `.env` file
# So anything already set in the environment wins over this file.
#
# This file uses the subset of .env syntax SparkSage supports:
#   KEY=VALUE | KEY="quoted" | KEY='quoted' | export KEY=VALUE | # comments
# Shell expansion ($VAR, $(...), backticks) is NOT interpreted.

# --- LLM / generation --------------------------------------------------------
# API key. SPARKSAGE_* takes priority over the OPENAI_* fallbacks below.
SPARKSAGE_API_KEY=
# OpenAI-compatible base URL. Omit for the public OpenAI endpoint; set for
# Azure / vLLM / Ollama / GLM / self-hosted / any custom endpoint.
# SPARKSAGE_BASE_URL=https://api.openai.com/v1
# Model id. Defaults to gpt-4o-mini when unset.
SPARKSAGE_MODEL=gpt-4o-mini
# Stream the LLM response (accumulate streamed deltas). On by default.
# Set to false/0/no/off to disable. 1/true/yes/on to enable.
SPARKSAGE_STREAM=true
# BCP-47 language code written into every generated IdeaBlock (e.g. en, zh).
SPARKSAGE_LANGUAGE=en

# --- Fallbacks (only used if the SPARKSAGE_* var above is unset) -------------
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
